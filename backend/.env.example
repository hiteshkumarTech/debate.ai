# DebateAI backend configuration.
# Copy this file to `.env` and fill in what you need. EVERYTHING here is
# optional — with no .env at all, the backend runs locally on SQLite, in
# dev-mode auth, with the echo AI fallback. You add values to turn on real
# services.

# --- App ---
ENVIRONMENT=development
# Comma-separated allowed frontend origins (add your deployed URL in prod)
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://127.0.0.1:5173

# --- Database ---
# Local dev (default): leave unset to use a local SQLite file.
# Production (Supabase): set your Postgres connection string, e.g.
# DATABASE_URL=postgresql+psycopg2://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres
# DATABASE_URL=sqlite:///./debateai.db

# --- Firebase Admin (auth) ---
# Path to the service-account JSON from Firebase Console > Project Settings
# > Service accounts > Generate new private key. When set, the backend
# verifies real Firebase ID tokens. When unset, it runs in dev-mode and
# trusts an "X-Dev-User" header instead.
# FIREBASE_CREDENTIALS_PATH=./firebase-service-account.json

# --- AI providers ---
# Set whichever you have. The default provider is used when a request
# doesn't specify one (or specifies one with no key). With none set, the
# backend returns labeled placeholder replies via the echo fallback.
DEFAULT_AI_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GOOGLE_API_KEY=...
