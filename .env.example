# Firebase config — get these from Firebase Console > Project Settings > General > Your apps
# Copy this file to .env.local and fill in your real values. Never commit .env.local.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Backend API — set to your running FastAPI backend's URL to enable real
# AI replies, persistence, analytics, and leaderboard. If left unset, the
# app falls back to local mock replies + localStorage (works fully offline).
# Local backend default:
VITE_API_URL=http://localhost:8000
